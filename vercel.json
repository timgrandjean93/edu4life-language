{
  "redirects": [
    {
      "source": "/:path*",
      "missing": [
        {
          "type": "host",
          "value": "education.wetlandrestorationhub.eu"
        }
      ],
      "destination": "https://education.wetlandrestorationhub.eu/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|.*\\..*|api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

